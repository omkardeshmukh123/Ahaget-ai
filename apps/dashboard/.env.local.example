# Copy this to .env.local and fill in your values

# Backend API URL — Railway URL in production (e.g. https://ahaget-backend.up.railway.app)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Widget CDN URL — jsDelivr in production
# e.g. https://cdn.jsdelivr.net/gh/omkardeshmukh123/Ahaget-ai@v1.1.0/dist/widget/widget.iife.js
NEXT_PUBLIC_WIDGET_URL=http://localhost:5173/widget.iife.js

# Stripe price IDs — must match backend .env (Stripe dashboard → Products)
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_...
NEXT_PUBLIC_STRIPE_PRICE_GROWTH=price_...
NEXT_PUBLIC_STRIPE_PRICE_SCALE=price_...

# Annual price IDs — leave blank to hide annual toggle
NEXT_PUBLIC_STRIPE_PRICE_STARTER_ANNUAL=
NEXT_PUBLIC_STRIPE_PRICE_GROWTH_ANNUAL=
NEXT_PUBLIC_STRIPE_PRICE_SCALE_ANNUAL=
