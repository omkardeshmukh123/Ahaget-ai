generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organization (your paying customer: a SaaS startup) ───────────────────
model Organization {
  id                   String   @id @default(uuid())
  name                 String
  apiKey               String   @unique @map("api_key")
  planType             String   @default("free") @map("plan_type")
  monthlyMessageLimit  Int      @default(1000) @map("monthly_message_limit")
  customInstructions   String?  @map("custom_instructions")
  // Stripe
  stripeCustomerId     String?  @unique @map("stripe_customer_id")
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  stripePriceId        String?  @map("stripe_price_id")
  subscriptionStatus   String   @default("inactive") @map("subscription_status") // inactive | active | past_due | canceled
  currentPeriodEnd     DateTime? @map("current_period_end")
  // Broken-selector alerts
  selectorAlertEnabled Boolean  @default(false) @map("selector_alert_enabled")
  selectorAlertWebhook String?  @map("selector_alert_webhook")
  languagePreference   String   @default("en") @map("language_preference")
  // Onboarding wizard fields (signup flow)
  websiteUrl           String?  @map("website_url")
  attribution          String?  // ai_search | google | linkedin | word_of_mouth | other
  onboardingStep       String   @default("workspace") @map("onboarding_step") // workspace | attribution | description | install | snippet | done
  onboardingComplete   Boolean  @default(false) @map("onboarding_complete")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  users                 User[]
  endUsers              EndUser[]
  conversations         Conversation[]
  events                Event[]
  checklistSteps        ChecklistStep[]
  followUpConfig        FollowUpConfig?
  onboardingFlows       OnboardingFlow[]
  onboardingSessions    UserOnboardingSession[]
  integrationConfigs    IntegrationConfig[]
  autoOptimizeConfig    AutoOptimizeConfig?
  optimizationLogs      OptimizationLog[]
  knowledgeBaseArticles KnowledgeBaseArticle[]
  selectorHealLogs      SelectorHealLog[]
  escalationTickets     EscalationTicket[]
  flowExperiments       FlowExperiment[]
  mcpConnectors         McpConnector[]
  auditLogs             AuditLog[]
  triggerRules          TriggerRule[]
  proactiveMessages     ProactiveMessage[]
  upsellAttributions    UpsellAttribution[]

  @@map("organizations")
}

// ─── User (admin/member of the org who logs into dashboard) ────────────────
model User {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  email          String    @unique
  passwordHash   String    @map("password_hash")
  name           String?
  role           String    @default("member") // owner | admin | member
  createdAt      DateTime  @default(now()) @map("created_at")
  lastLoginAt    DateTime? @map("last_login_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("users")
}

// ─── EndUser (the actual user of the customer's SaaS product) ──────────────
model EndUser {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  externalId     String?  @map("external_id") // customer's own user ID
  email          String?  // for proactive out-of-app emails
  metadata       Json     @default("{}") // plan, page, any custom data
  firstSeenAt    DateTime @default(now()) @map("first_seen_at")
  lastSeenAt     DateTime @default(now()) @map("last_seen_at")
  unsubscribed   Boolean  @default(false) // opt-out of proactive emails

  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations       Conversation[]
  events              Event[]
  onboardingSessions  UserOnboardingSession[]
  escalationTickets   EscalationTicket[]
  proactiveMessages   ProactiveMessage[]
  upsellAttributions  UpsellAttribution[]

  @@unique([organizationId, externalId])
  @@index([organizationId])
  @@map("end_users")
}

// ─── Conversation ───────────────────────────────────────────────────────────
model Conversation {
  id             String    @id @default(uuid())
  endUserId      String    @map("end_user_id")
  organizationId String    @map("organization_id")
  status         String    @default("active") // active | closed
  triggeredBy    String?   @map("triggered_by") // idle | exit_intent | manual
  startedAt      DateTime  @default(now()) @map("started_at")
  endedAt        DateTime? @map("ended_at")

  endUser      EndUser      @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([endUserId])
  @@index([organizationId])
  @@map("conversations")
}

// ─── Message ────────────────────────────────────────────────────────────────
model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String   // user | assistant
  content        String
  tokensUsed     Int      @default(0) @map("tokens_used")
  createdAt      DateTime @default(now()) @map("created_at")
  metadata       Json     @default("{}")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt(sort: Desc)])
  @@map("messages")
}

// ─── ChecklistStep (steps admins define for their end-user onboarding) ────────
model ChecklistStep {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  label          String                               // "Connect your data source"
  description    String   @default("")
  order          Int      @default(0)
  completionEvent String? @map("completion_event")   // event type that auto-marks done (optional)
  isRequired     Boolean  @default(true) @map("is_required")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, order])
  @@map("checklist_steps")
}

// ─── FollowUpConfig (per-org multi-channel follow-up settings) ────────────────
model FollowUpConfig {
  id                  String   @id @default(uuid())
  organizationId      String   @unique @map("organization_id")
  emailEnabled        Boolean  @default(false) @map("email_enabled")
  slackWebhookUrl     String?  @map("slack_webhook_url")
  whatsappEnabled     Boolean  @default(false) @map("whatsapp_enabled")
  twilioAccountSid    String?  @map("twilio_account_sid")
  twilioAuthToken     String?  @map("twilio_auth_token")
  twilioFromNumber    String?  @map("twilio_from_number")
  followUpDelayMins   Int      @default(30) @map("follow_up_delay_mins")
  emailSubject        String   @default("Still need help?") @map("email_subject")
  emailBody           String   @default("Hi! You were setting things up earlier. Want to pick up where you left off?") @map("email_body")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("follow_up_configs")
}

// ─── AgentFlow types ──────────────────────────────────────────────────────────
// onboarding | adoption | upsell | retention | support
// Priority order for selector: retention > upsell > adoption > onboarding > support

// ─── OnboardingFlow (unified AgentFlow — covers full user lifecycle) ──────────
model OnboardingFlow {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  description    String   @default("")
  isActive       Boolean  @default(true) @map("is_active")
  // Flow type — determines lifecycle stage and selector priority
  flowType       String   @default("onboarding") @map("flow_type") // onboarding | adoption | upsell | retention | support
  triggerCondition Json   @default("{}") @map("trigger_condition") // {type, urlPattern, eventName, inactiveDays, usageThreshold, featureSlug}
  executionMode  String   @default("execute") @map("execution_mode") // recommend | guided | execute
  // Trigger controls — when and where the widget fires
  triggerDelayMs      Int    @default(30000) @map("trigger_delay_ms")     // ms after page load
  urlPattern          String @default("") @map("url_pattern")             // comma-separated patterns, empty = all pages
  maxTriggersPerUser  Int    @default(0)   @map("max_triggers_per_user")  // 0 = unlimited
  targetRoles         String[] @default([]) @map("target_roles")             // empty = all roles
  // Upsell flow fields (flowType = 'upsell')
  targetPlan          String?  @map("target_plan")    // e.g. 'growth', 'pro', 'enterprise'
  upgradeUrl          String?  @map("upgrade_url")    // deep link to checkout / billing page
  mrrPerConversion    Float?   @map("mrr_per_conversion") // estimated MRR value per attributed upgrade
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps               OnboardingStep[]
  sessions            UserOnboardingSession[]
  triggerRules        TriggerRule[]
  controlExperiments  FlowExperiment[]       @relation("ExperimentControl")
  variantExperiments  FlowExperiment[]       @relation("ExperimentVariant")
  upsellAttributions  UpsellAttribution[]
  proactiveMessages   ProactiveMessage[]

  @@index([organizationId])
  @@index([organizationId, flowType])
  @@map("onboarding_flows")
}

// ─── FlowExperiment (A/B test: compare two flow variants) ───────────────────
model FlowExperiment {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String
  status         String    @default("running") // running | paused | concluded
  controlFlowId  String    @map("control_flow_id")
  variantFlowId  String    @map("variant_flow_id")
  trafficSplit   Int       @default(50) @map("traffic_split") // % routed to variant (0-100)
  winnerId       String?   @map("winner_id")    // flow id of declared winner
  startedAt      DateTime  @default(now()) @map("started_at")
  concludedAt    DateTime? @map("concluded_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  controlFlow  OnboardingFlow @relation("ExperimentControl", fields: [controlFlowId], references: [id], onDelete: Cascade)
  variantFlow  OnboardingFlow @relation("ExperimentVariant", fields: [variantFlowId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("flow_experiments")
}

// ─── OnboardingStep (one step in the journey, with AI config + action) ───────
model OnboardingStep {
  id              String   @id @default(uuid())
  flowId          String   @map("flow_id")
  order           Int
  title           String   // "Connect your data source"
  intent          String   @default("") // "data_connection" — user goal keyword
  description     String   @default("")
  aiPrompt        String   @default("") @map("ai_prompt")     // extra instructions for AI on this step
  smartQuestions  Json     @default("[]") @map("smart_questions") // up to 2 questions to ask
  actionType      String?  @map("action_type") // fill_form | click | navigate | api_call | none
  actionConfig    Json     @default("{}") @map("action_config")   // {selector, url, fields, ...}
  allowedActions  Json     @default("[]") @map("allowed_actions") // [] = all allowed; e.g. ["highlight","navigate"] = read-only
  completionEvent String?  @map("completion_event") // event that auto-marks step done
  isMilestone     Boolean  @default(false) @map("is_milestone") // this step = "aha moment"
  targetUrl       String?  @map("target_url") // optional page this step should run on (e.g. "/settings" or "https://external.com")
  createdAt       DateTime @default(now()) @map("created_at")

  flow             OnboardingFlow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  progress         UserStepProgress[]
  optimizationLogs OptimizationLog[]

  @@index([flowId, order])
  @@map("onboarding_steps")
}

// ─── UserOnboardingSession (tracks one user's journey through a flow) ─────────
model UserOnboardingSession {
  id             String    @id @default(uuid())
  endUserId      String    @map("end_user_id")
  organizationId String    @map("organization_id")
  flowId         String    @map("flow_id")
  currentStepId  String?   @map("current_step_id")
  status         String    @default("active") // active | completed | abandoned
  firstValueAt   DateTime? @map("first_value_at") // when aha moment was reached
  startedAt      DateTime  @default(now()) @map("started_at")
  completedAt    DateTime? @map("completed_at")
  lastActiveAt   DateTime  @default(now()) @map("last_active_at")
  collectedData  Json      @default("{}") @map("collected_data") // answers to smart questions

  // A/B experiment tracking — null for sessions not part of an experiment
  experimentId      String? @map("experiment_id")
  experimentVariant String? @map("experiment_variant") // "control" | "variant"

  endUser      EndUser               @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  flow         OnboardingFlow        @relation(fields: [flowId], references: [id], onDelete: Cascade)
  stepProgress UserStepProgress[]
  messages     SessionMessage[]

  @@unique([endUserId, flowId])
  @@index([organizationId])
  @@index([flowId])
  @@index([experimentId])
  @@map("user_onboarding_sessions")
}

// ─── SessionMessage (per-session conversation history for the AI agent) ────────
model SessionMessage {
  id         String   @id @default(uuid())
  sessionId  String   @map("session_id")
  stepId     String   @map("step_id")
  role       String   // user | assistant
  content    String   // raw text or JSON action summary
  actionType String?  @map("action_type") // ask_clarification | execute_page_action | complete_step | etc.
  createdAt  DateTime @default(now()) @map("created_at")

  feedback  Int?     // 1 = thumbs up, -1 = thumbs down, null = no feedback
  session UserOnboardingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt(sort: Desc)])
  @@map("session_messages")
}

// ─── UserStepProgress (per-step completion tracking + intelligence pipeline) ───
model UserStepProgress {
  id          String    @id @default(uuid())
  sessionId   String    @map("session_id")
  stepId      String    @map("step_id")
  status      String    @default("not_started") // not_started | in_progress | completed | skipped
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  timeSpentMs Int       @default(0) @map("time_spent_ms")
  attempts    Int       @default(0)
  aiAssisted  Boolean   @default(false) @map("ai_assisted")
  // ── Intelligence pipeline fields (feed Phase 3 prompt optimization) ──────────
  promptSnapshot  String?  @map("prompt_snapshot")   // exact AI prompt used at completion time
  messagesCount   Int      @default(0) @map("messages_count") // turns it took to complete
  dropReason      String?  @map("drop_reason")       // "idle" | "exit" | "explicit_skip" | null
  outcome         String?  // "completed" | "dropped" | "skipped" — redundant with status but fast to query

  session UserOnboardingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  step    OnboardingStep        @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([sessionId, stepId])
  @@index([stepId])
  @@map("user_step_progress")
}

// ─── AutoOptimizeConfig (per-org auto-improvement settings) ───────────────────
model AutoOptimizeConfig {
  id              String   @id @default(uuid())
  organizationId  String   @unique @map("organization_id")
  enabled         Boolean  @default(false)
  threshold       Int      @default(50)  // optimize when completion rate < this %
  minSessions     Int      @default(10)  @map("min_sessions") // min data before triggering
  lastRunAt       DateTime? @map("last_run_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("auto_optimize_configs")
}

// ─── OptimizationLog (history of auto + manual prompt optimizations) ──────────
model OptimizationLog {
  id                   String   @id @default(uuid())
  organizationId       String   @map("organization_id")
  stepId               String   @map("step_id")
  flowId               String   @map("flow_id")
  triggeredBy          String   @map("triggered_by") // "auto" | "manual"
  previousPrompt       String?  @map("previous_prompt")
  newPrompt            String   @map("new_prompt")
  completionRateBefore Float?   @map("completion_rate_before")
  reason               String   @default("")
  appliedAt            DateTime @default(now()) @map("applied_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  step         OnboardingStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([organizationId, appliedAt(sort: Desc)])
  @@map("optimization_logs")
}

// ─── IntegrationConfig (per-org outbound integrations) ────────────────────────
model IntegrationConfig {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  type           String    // segment | mixpanel | hubspot | webhook
  enabled        Boolean   @default(true)
  credentials    Json      @default("{}") // {writeKey, token, apiKey, url}
  settings       Json      @default("{}") // {trackEvents, contactEmailField}
  lastFiredAt    DateTime? @map("last_fired_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
  @@map("integration_configs")
}

// ─── Event (user behavior tracking) ─────────────────────────────────────────
model Event {
  id             String   @id @default(uuid())
  endUserId      String   @map("end_user_id")
  organizationId String   @map("organization_id")
  eventType      String   @map("event_type") // page_view | idle | exit_intent | click
  properties     Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  endUser      EndUser      @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([endUserId])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([eventType])
  @@map("events")
}

// ─── EscalationTicket (human handoff request from the AI agent) ──────────────
model EscalationTicket {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  endUserId      String    @map("end_user_id")
  sessionId      String    @map("session_id")
  stepId         String?   @map("step_id")
  trigger        String    // "agent_detected" | "user_requested"
  status         String    @default("open") // open | in_progress | resolved
  reason         String    // why escalation was triggered
  agentMessage   String    @map("agent_message") // message shown to user
  context        Json      @default("{}") @map("context") // conversation, collected data, user info
  notes          String?   // support team notes
  resolvedAt     DateTime? @map("resolved_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  endUser      EndUser      @relation(fields: [endUserId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([endUserId])
  @@map("escalation_tickets")
}

// ─── SelectorHealLog (self-healing resolver telemetry) ───────────────────────
model SelectorHealLog {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  sessionId         String?  @map("session_id")
  stepId            String?  @map("step_id")
  originalSelector  String   @map("original_selector")
  usedSelector      String?  @map("used_selector")   // null when strategy = 'failed'
  strategy          String                            // primary|data-testid|name|aria-label|placeholder|exact-text|fuzzy-class|fuzzy-text|failed
  actionType        String?  @map("action_type")      // click|fill_form|highlight
  page              String
  createdAt         DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, originalSelector])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([stepId])
  @@map("selector_heal_logs")
}

// ─── KnowledgeBaseArticle (org-specific docs the AI searches during onboarding) ─
model KnowledgeBaseArticle {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  title          String
  content        String   // plain text or markdown
  tags           String[] @default([])
  embedding      Json     @default("[]") @map("embedding") // float[] from text-embedding-3-small
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("knowledge_base_articles")
}

// ─── McpConnector (Model Context Protocol server connections) ─────────────────
// Each connector points to an MCP server URL. The AI agent uses these to call
// external tools (databases, APIs, internal services) during onboarding flows.
model McpConnector {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String                              // human label, e.g. "Production DB"
  serverUrl      String   @map("server_url")        // MCP server endpoint
  authType       String   @default("none") @map("auth_type") // none | bearer | api_key
  authValue      String?  @map("auth_value")        // bearer token or API key
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("mcp_connectors")
}

// ─── AuditLog (every action the AI took, per org — for compliance + debugging) ─
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  sessionId      String?  @map("session_id")
  endUserId      String?  @map("end_user_id")
  stepId         String?  @map("step_id")
  actionType     String   @map("action_type") // ask_clarification | fill_form | click | navigate | highlight | complete_step | escalate_to_human
  payload        Json     @default("{}") // action-specific details (selector, url, fields, message, etc.)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([sessionId])
  @@map("audit_logs")
}

// ─── TriggerRule (when the AI employee wakes up and acts) ─────────────────────
// Each rule is linked to one AgentFlow and defines the condition that activates it.
// Trigger types:
//   page_visit         — user visits a URL matching pattern (optionally first-time only)
//   page_never_visited — user has NOT visited URL after N days
//   usage_threshold    — user hits X% of a plan metric
//   event_fired        — a specific event name fires
//   inactivity         — user hasn't logged in for N days
//   feature_unused     — user hasn't used a feature slug for N days
model TriggerRule {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  flowId         String   @map("flow_id")
  triggerType    String   @map("trigger_type") // page_visit | page_never_visited | usage_threshold | event_fired | inactivity | feature_unused
  isActive       Boolean  @default(true) @map("is_active")
  // Type-specific config (all optional — use what's relevant for the type)
  urlPattern     String?  @map("url_pattern")       // page_visit | page_never_visited: regex or glob
  firstTimeOnly  Boolean  @default(false) @map("first_time_only") // page_visit: only fire on first ever visit
  daysThreshold  Int?     @map("days_threshold")    // inactivity | page_never_visited | feature_unused
  eventName      String?  @map("event_name")        // event_fired: exact event type string
  usageMetric    String?  @map("usage_metric")      // usage_threshold: metric key (api_calls, seats, etc.)
  usagePercent   Int?     @map("usage_percent")     // usage_threshold: 0-100
  featureSlug    String?  @map("feature_slug")      // feature_unused: internal feature identifier
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  flow         OnboardingFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([flowId])
  @@map("trigger_rules")
}

// ─── ProactiveMessage (agent initiates outreach) ──────────────────────────────
// Tracks every proactive message sent to an end-user — both in-app badge and
// out-of-app email. Used for deduplication (max 1 per user per 48 hours) and
// for the "Outreach" dashboard panel.
//
// channel: "in_app" | "email"
// status:  "sent" | "opened" | "clicked" | "unsubscribed"
model ProactiveMessage {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  endUserId      String   @map("end_user_id")
  flowId         String   @map("flow_id")           // which flow triggered the message
  triggerRuleId  String?  @map("trigger_rule_id")   // which rule fired (nullable for manual sends)
  channel        String   @map("channel")            // in_app | email
  subject        String?                             // email only
  bodySnippet    String?  @map("body_snippet")       // first 200 chars of message body
  deepLink       String?  @map("deep_link")          // ?ahaget_resume= URL sent in email
  status         String   @default("sent")           // sent | opened | clicked | unsubscribed
  sentAt         DateTime @default(now()) @map("sent_at")
  openedAt       DateTime? @map("opened_at")
  clickedAt      DateTime? @map("clicked_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  endUser      EndUser        @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  flow         OnboardingFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([organizationId, sentAt(sort: Desc)])
  @@index([endUserId, sentAt(sort: Desc)])
  @@map("proactive_messages")
}

// ─── UpsellAttribution ────────────────────────────────────────────────────────
// Records when a user upgrades within 48h of an AI-initiated upsell interaction.
// Used to calculate Ahaget-attributed expansion MRR on the dashboard.
//
// status: pending | confirmed | rejected
//   pending  = upgrade detected within window but not yet confirmed by billing webhook
//   confirmed = billing webhook confirmed plan change matches targetPlan
//   rejected  = window expired with no upgrade
model UpsellAttribution {
  id               String    @id @default(uuid())
  organizationId   String    @map("organization_id")
  endUserId        String    @map("end_user_id")
  flowId           String    @map("flow_id")              // which upsell flow ran
  sessionId        String?   @map("session_id")           // which session showed the upgrade card
  targetPlan       String    @map("target_plan")          // plan the user was pitched
  attributionWindowH Int     @default(48) @map("attribution_window_h") // hours the window is open
  status           String    @default("pending")          // pending | confirmed | rejected
  mrr              Float?                                  // MRR value at confirmation (from billing webhook or mrrPerConversion)
  suggestedAt      DateTime  @default(now()) @map("suggested_at")
  confirmedAt      DateTime? @map("confirmed_at")
  expiresAt        DateTime  @map("expires_at")           // suggestedAt + attributionWindowH

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  flow         OnboardingFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  endUser      EndUser        @relation(fields: [endUserId], references: [id], onDelete: Cascade)

  @@index([organizationId, suggestedAt(sort: Desc)])
  @@index([endUserId, suggestedAt(sort: Desc)])
  @@index([status])
  @@map("upsell_attributions")
}
