    "@types/multer": "^2.1.0",
    "@upstash/redis": "^1.28.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.7",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-html-markdown": "^2.0.0",
    "openai": "^4.47.0",
    "resend": "^3.2.0",
    "stripe": "^14.21.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
