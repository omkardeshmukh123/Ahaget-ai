# Copy this to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL — get free DB from supabase.com or neon.tech
DATABASE_URL="postgresql://postgres:password@localhost:5432/ahaget"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-here"

# ─── AI Models ───────────────────────────────────────────────────────────────
# OpenRouter — primary AI agent (openrouter.ai/keys)
OPENROUTER_API_KEY="sk-or-..."

# OpenAI — embeddings only (platform.openai.com/api-keys)
OPENAI_API_KEY="sk-proj-..."

# Sarvam AI — Indian language support (sarvam.ai) — optional
SARVAM_API_KEY=""

# ─── Redis — Upstash ─────────────────────────────────────────────────────────
# Create a Redis DB at upstash.com → REST API tab → copy URL and Token
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Stripe Billing ──────────────────────────────────────────────────────────
# dashboard.stripe.com → API keys
STRIPE_SECRET_KEY="sk_test_..."
# From: stripe listen --forward-to localhost:4000/api/v1/billing/webhook
# Or from Stripe dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# Monthly price IDs (Stripe dashboard → Products)
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_GROWTH="price_..."
STRIPE_PRICE_SCALE="price_..."

# Annual price IDs (optional — leave blank to disable annual billing)
STRIPE_PRICE_STARTER_ANNUAL=""
STRIPE_PRICE_GROWTH_ANNUAL=""
STRIPE_PRICE_SCALE_ANNUAL=""

# ─── Email — Resend ──────────────────────────────────────────────────────────
# resend.com → API Keys (3k emails/mo free)
RESEND_API_KEY="re_..."

# ─── Security ────────────────────────────────────────────────────────────────
# Admin panel header — any random secret string
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_SECRET="your-admin-secret-here"

# MCP connector credential encryption — 64 hex chars (optional but recommended)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Set to your dashboard URL in production (e.g. https://app.ahaget.com)
FRONTEND_URL="http://localhost:3000"
