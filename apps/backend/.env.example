# Copy this to .env and fill in your values

# PostgreSQL — get free DB from supabase.com or neon.tech
DATABASE_URL="postgresql://postgres:password@localhost:5432/ahaget"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-here"

# OpenAI API — get from platform.openai.com
OPENAI_API_KEY="sk-..."

# Upstash Redis — get free from upstash.com (used for rate limiting & magic-link tokens)
# Create a Redis DB → copy REST URL and REST Token
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Stripe — get from dashboard.stripe.com
# 1. Create products: Free / Starter ($99) / Growth ($299) / Scale ($999)
# 2. Copy each price ID below
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."   # from: stripe listen --forward-to localhost:4000/api/v1/billing/webhook
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_GROWTH="price_..."
STRIPE_PRICE_SCALE="price_..."

# Email — get free API key from resend.com (3k emails/mo free)
RESEND_API_KEY="re_..."

# Sarvam AI — Indian language support (https://www.sarvam.ai)
SARVAM_API_KEY=""

# Admin panel — any secret string, used in X-Admin-Secret header
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_SECRET="your-admin-secret-here"

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
